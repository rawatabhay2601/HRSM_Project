# HRMS Lite - Environment variables
# Copy this file to .env and set values as needed.
# The app loads .env automatically (python-dotenv + pydantic-settings).

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# PostgreSQL (Supabase or any Postgres) or SQLite.
# If Supabase connection times out on port 5432, use the pooler (port 6543) or SQLite for local dev.
#
# Supabase pooler (recommended for external connections):
# DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require
#
# Supabase direct (port 5432):
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require
#
# Local PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/hrms_lite
#
# SQLite (local development):
DATABASE_URL=sqlite:///./hrms_lite.db

# Set to true to log SQL statements (debug only).
# ECHO_SQL=false

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
# ENVIRONMENT=development
# LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
# Comma-separated list of allowed origins (e.g. React / Vite dev servers).
# Default includes localhost:3000 and localhost:5173.
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173
